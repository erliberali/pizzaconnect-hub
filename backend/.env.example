# Supabase (pegar no Dashboard > Project Settings > API)
SUPABASE_URL="https://SEU_PROJECT_ID.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # Service Role Key — nunca expor ao frontend

# JWT
JWT_SECRET="troque-por-um-secret-seguro"
JWT_EXPIRES_IN="7d"

# URL do frontend (para CORS)
FRONTEND_URL="http://localhost:8080"

# CardapioWeb API
# Verificar URL exata no painel CardapioWeb > Configurações > Integrações > API
CARDAPIOWEB_BASE_URL="https://api.cardapioweb.com.br/v1"
CARDAPIOWEB_TIMEOUT_MS="10000"

# Peché Pizzaria — credenciais CardapioWeb
PECHE_ESTABELECIMENTO_ID=""
PECHE_API_KEY=""
PECHE_PARTNER_KEY=""

# Mozzarella Mais — credenciais CardapioWeb
MOZZ_ESTABELECIMENTO_ID=""
MOZZ_API_KEY=""
MOZZ_PARTNER_KEY=""

# Reconciliador (cron — padrão: a cada 10 min)
RECONCILIADOR_CRON="*/10 * * * *"

# Porta do servidor
PORT="3001"
